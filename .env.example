# =====================================================
# BOT TELE - Configuration File
# Copy this to .env and fill in your credentials
# =====================================================

# ==========================================
# 🔑 TELEGRAM CREDENTIALS (REQUIRED)
# ==========================================
# Get from: https://my.telegram.org/apps
API_ID=20451785
API_HASH=f93e22ca85ce0e5c107e5a8027eb4bf4
SESSION_NAME=session_bot_full

# ==========================================
# 📝 LOGGING
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=logs/bot_activity.log
MAX_LOG_SIZE=10485760
BACKUP_COUNT=5

# ==========================================
# 📋 FILES & PARAMETERS
# ==========================================
DATABASE_PATH=data/code_history.db
BROWSER_PROFILE_DIR=HoSo_Bot_Vip
CODE_MIN_LENGTH=6
CODE_MAX_LENGTH=15

# ==========================================
# 🌐 CDP CONNECTION
# ==========================================
CDP_HOST=localhost
CDP_PORT=9222
CDP_TIMEOUT=10
CDP_RETRY_ATTEMPTS=3

# ==========================================
# 🖥️ BROWSER CONFIGURATION
# ==========================================
# BROWSER_TYPE=firefox
# VIEWPORT_WIDTH=1024
# VIEWPORT_HEIGHT=768
# HEADLESS_MODE=False

# ==========================================
# ⏱️ TIMEOUTS (milliseconds)
# ==========================================
PAGE_LOAD_TIMEOUT=15000
CLOUDFLARE_WAIT_TIMEOUT=60000
PAGE_LOAD_MAX_RETRIES=3
PAGE_LOAD_RETRY_DELAY=2.0
SUBMIT_TASK_TIMEOUT=30

# ==========================================
# ⚡ PERFORMANCE
# ==========================================
MAX_CONCURRENT_TASKS=3
MIN_DELAY_BETWEEN_SUBMITS=0.8
REQUESTS_PER_MINUTE=30

# ==========================================
# 🔄 BATCH PROCESSING
# ==========================================
BATCH_MODE_ENABLED=True
BATCH_SIZE=5
BATCH_WAIT_TIME=0.5

# ==========================================
# 🏥 HEALTH CHECK
# ==========================================
HEALTH_CHECK_ENABLED=True
HEALTH_CHECK_INTERVAL=60
AUTO_RECOVERY_ENABLED=True

# ==========================================
# 📊 PERFORMANCE TRACKING
# ==========================================
PERFORMANCE_TRACKING_ENABLED=True
PERFORMANCE_REPORT_INTERVAL=300

# ==========================================
# 🤖 AUTO-SUBMIT
# ==========================================
AUTO_SUBMIT_ENABLED=True
AUTO_SUBMIT_DELAY=0.3
HUMAN_LIKE_TYPING_SPEED=0.05
RANDOM_DELAY_MIN=0.1
RANDOM_DELAY_MAX=0.5

# ==========================================
# 🔍 INPUT DETECTION
# ==========================================
INPUT_DETECTION_STRATEGY=advanced
INPUT_DETECTION_TIMEOUT=5000
MULTIPLE_SELECTOR_ATTEMPTS=10

# ==========================================
# 📊 RESULT DETECTION
# ==========================================
RESULT_DETECTION_METHODS=5
RESULT_DETECTION_TIMEOUT=5000
SCREENSHOT_ON_UNKNOWN=True
